# =================
# DATABASE
# =================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mataremitos?schema=public"

# =================
# REDIS (BullMQ)
# =================
REDIS_URL="redis://localhost:6379"

# =================
# AUTHENTICATION
# =================
JWT_SECRET="cambia-esto-por-un-secreto-de-al-menos-32-caracteres-aleatorios"
JWT_EXPIRES_IN="7d"

# =================
# AI PROVIDERS
# =================
# Gemini (primer pass — obtener en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=""

# Anthropic Claude (fallback de alta confianza — obtener en https://console.anthropic.com)
ANTHROPIC_API_KEY=""

# =================
# STORAGE (S3-compatible: MinIO local o Cloudflare R2 en producción)
# =================
# MinIO local:
#   docker run -p 9000:9000 -p 9001:9001 \
#     -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
#     minio/minio server /data --console-address ":9001"
#   Crear bucket "mata-remitos" en http://localhost:9001
#
# Cloudflare R2 en producción:
#   STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   STORAGE_ACCESS_KEY=<R2 access key>
#   STORAGE_SECRET_KEY=<R2 secret key>
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_BUCKET="mata-remitos"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_REGION="us-east-1"
STORAGE_PUBLIC_URL="http://localhost:9000/mata-remitos"

# =================
# WHATSAPP BUSINESS
# =================
# Provider: 360dialog | twilio
WHATSAPP_PROVIDER="360dialog"
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# =================
# APP
# =================
NODE_ENV="development"
PORT="3000"
ALLOWED_ORIGINS="http://localhost:3001"
LOG_LEVEL="debug"

# =================
# FRONTEND
# =================
NEXT_PUBLIC_API_URL="http://localhost:3000"
